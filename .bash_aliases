alias lib="cd ~/.local/lib/ben"

alias bashrc='$EDITOR ~/.bashrc'
alias cdu='cd ~/src/uinta'
alias config='/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME'
alias docs='cd ~/Documents'
alias down='cd ~/Downloads'
alias l='ls'
alias ll='ls -lah'
alias make='make -j 32'
alias mpv='mpv --sid=no'
alias nvimrc='$EDITOR ~/.config/nvim/init.vim'
alias pac='pacman'
alias passotp='pass otp code --clip'
alias rsync='rsync -v'
alias src='cd ~/src'
alias tv='cd ~/Videos/tv'
alias v='$EDITOR'
alias vimide='$EDITOR ~/.config/ben/ide.vim'
alias vimrc='$EDITOR ~/.vimrc'
alias youtube-dl-a='youtube-dl -f bestaudio/best'
alias youtube-dl='youtube-dl --force-ipv4'

# torrent alises
alias t-start='sudo service transmission-daemon start'
alias t-stop='sudo service transmission-daemon stop'
alias t-reload='sudo service transmission-daemon reload'
alias t-list='transmission-remote -n 'transmission:transmission' -l'
alias t-basicstats='transmission-remote -n 'transmission:transmission' -st'
alias t-fullstats='transmission-remote -n 'transmission:transmission' -si'
alias t-show='watch -n 1 transmission-remote -n 'transmission:transmission' -l'
alias t-add='transmission-remote -a '
alias t-delete='transmission-remote -r -t'
alias t-del='t-delete'
alias t-move='mv /var/lib/transmission-daemon/downloads/* ~/Downloads/torrents'
