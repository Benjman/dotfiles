#!/usr/bin/sh

info=$(upower -i /org/freedesktop/UPower/devices/headset_dev_14_3F_A6_09_82_23 2> /dev/null)

[[ ! "$info" || $(echo "$info" | awk '/has history/{print $3'}) = "no" ]] && exit 0

percentage=$(echo "$info" | awk '/percentage/{print $2}' | sed "s/%//")
state=$(echo "$info" | awk '/state/{print $2}')

[ "$percentage" -le "15" ] && [ "$state" = "discharging" ] && warn="❗"

printf "%s%s %d%%\\n" "🎧" "$warn" "$percentage" ; unset warn
