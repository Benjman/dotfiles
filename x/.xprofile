#!/bin/env /bin/bash

# Random Photo Every Login
feh --bg-fill --randomize ~/.local/share/backgrounds

# Monitor Config
# xrandr --auto --output DVI-D-0 --mode 2560x1440 --left-of HDMI-0
# xrandr --output DP-1 --mode 2560x1440 --rate 59.95
# xrandr --auto --output HDMI-1 --mode 2560x1440 --left-of DP-1

source /etc/profile.d/vte.sh

# Don't Randomly Turn off
xset s off
xset -dpms
xset s noblank

# Speedy keys
xset r rate 210 40

# Environment variables set everywhere
export XDG_CACHE_HOME=$HOME/.cache
export XDG_CONFIG_HOME=$HOME/.config
export XDG_DATA_HOME=$HOME/.local/share

source $XDG_CONFIG_HOME/user-dirs.dirs
xrdb $XDG_CONFIG_HOME/x/Xresources & xrdbpid=$! # Uncomment to use Xresources colors/settings on startup

export BROWSER=/bin/brave
export EDITOR=/bin/nvim
export PAGER=/bin/less
export VISUAL=$EDITOR

export PATH="$HOME/.local/bin:$PATH"

# bind escape to caps
[[ "${XDG_SESSION_TYPE@u}" == "X11" ]] && setxkbmap -option caps:escape
[[ "${XDG_SESSION_TYPE@u}" == "WAYLAND" ]] && gsettings set org.gnome.desktop.input-sources xkb-options "['caps:escape']"
# When caps lock is pressed only once, treat it as escape.
killall xcape 2>/dev/null ; xcape -e 'Super_L=Escape'
# Turn off caps lock if on since there is no longer a key for it.
xset -q | grep "Caps Lock:\s*on" && xdotool key Caps_Lock

# Status Bar
[[ -x /usr/local/bin/dwmblocks ]] && dwmblocks &

# lock screen after `--time n` minutes
[[ -x /usr/bin/xautolock && -x /usr/local/bin/slock ]] && xautolock -time 5 -locker slock &

# For QT Themes
# export QT_QPA_PLATFORMTHEME=qt5ct

# Compositor
[[ -x /usr/bin/picom ]] && picom &

# Hide mouse when typing
[[ -x /usr/bin/xbanish ]] && xbanish &

# Screenshots
[[ -x /usr/bin/flameshot ]] && flameshot &

# Audio
[[ -x /usr/bin/pipewire ]] && pipewire &

# Bluetooth systray icon
# blueman-applet &

# Network Manager Applet
# nm-applet --indicator &

# helps with puls audio
# pasystray &

# Ensure that xrdb has finished running before moving on to start the WM/DE.
[ -n "$xrdbpid" ] && wait "$xrdbpid"
