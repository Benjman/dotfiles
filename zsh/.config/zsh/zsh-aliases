#!/bin/sh
alias aliases="$EDITOR $ZDOTDIR/zsh-aliases && source $ZDOTDIR/.zshrc"
alias cp="cp -i"
alias df="df -h"
alias dots="cd ~/.dotfiles"
alias down="cd $XDG_DOWNLOAD_DIR"
alias egrep="egrep --colour=auto"
alias exports="pushd . > /dev/null && $EDITOR $ZDOTDIR/zsh-exports && source $ZDOTDIR/.zshrc"
alias fgrep="fgrep --colour=auto"
alias grep="grep --colour=auto"
alias lf="lfub"
alias lg="lazygit"
alias ll="ls -lah"
alias ls="ls --color=auto"
alias make="make -j32"
alias mpv="mpv --sid=no"
alias newsboaturls="$EDITOR $XDG_CONFIG_HOME/newsboat/urls"
alias rc="pushd . > /dev/null && cd $ZDOTDIR && $EDITOR && source $ZDOTDIR/.zshrc && popd > /dev/null"
alias ss="pushd . > /dev/null && cd ~/.local/lib/scripts && $EDITOR && popd > /dev/null"
alias trash="trash --trash-dir=/tmp/trash"
alias v=$EDITOR
alias vim="/bin/nvim"
alias vim=$EDITOR
alias vimc="pushd . > /dev/null && cd $XDG_CONFIG_HOME/nvim && $EDITOR && popd > /dev/null"
alias vimd="cd $XDG_CONFIG_HOME/nvim"
alias wget="wget --hsts-file=/dev/null"
alias zd="cd $ZDOTDIR"
