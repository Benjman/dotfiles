#!/bin/sh
alias aliases="$EDITOR $ZDOTDIR/zsh-aliases && source $ZDOTDIR/.zshrc"
alias cp="cp -i"
alias df="df -h"
alias dots="cd ~/.dotfiles"
alias egrep="egrep --colour=auto"
alias fgrep="fgrep --colour=auto"
alias grep="grep --colour=auto"
alias lf="lfub"
alias lg="lazygit"
alias ll="ls -lah"
alias ls="ls --color=auto"
alias make="make -j32"
alias mpv="mpv --sid=no"
alias src="cd ~/.local/src"
alias trash="trash --trash-dir=/tmp/trash"
alias vim=$EDITOR
alias vimc="pushd . 1> /dev/null && cd $XDG_CONFIG_HOME/nvim && $EDITOR && popd 1> /dev/null"
alias wget="wget --no-hsts"
alias zrc="pushd . 1> /dev/null && cd $ZDOTDIR && $EDITOR && popd 1> /dev/null"
